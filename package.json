{
	"name": "agent247",
	"version": "0.1.0",
	"description": "Local LLM agent task scheduler",
	"type": "module",
	"bin": {
		"agent247": "./dist/cli.js"
	},
	"scripts": {
		"build": "tsc && mkdir -p dist/templates && cp src/templates/.gitignore.workspace dist/templates/.gitignore.workspace && git rev-parse --short HEAD > dist/version.txt",
		"dev": "tsx src/cli.ts",
		"lint": "biome check --write .",
		"lint:ci": "biome check .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"highlight.js": "^11.11.1",
		"js-yaml": "^4.1.1",
		"ulid": "^3.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.5.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	}
}
